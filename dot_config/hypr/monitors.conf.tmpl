
################
### MONITORS ###
################

{{- if eq .hostname "desktop" }}
$main_monitor = DP-2
$side_monitor = DP-1

# See https://wiki.hypr.land/Configuring/Monitors/
monitor= $main_monitor, 2560x1440@240, 0x0, 1, transform, 0
monitor= $side_monitor, 1920x1080@240, -1080x-450, 1, transform, 1

{{- else if eq .hostname "laptop" }}
$main_monitor = DP-1

monitor= $main_monitor,preferred,auto,1
monitor= ,preferred,auto,1,mirror,eDP-1

{{- else }}
monitor=,preferred,auto,1
{{- end }}




